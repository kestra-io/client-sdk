{
  "name": "@kestra-io/kestra-sdk",
  "version": "0.0.0-dev",
  "description": "All API operations, except for Superadmin-only endpoints, require a tenant identifier in the HTTP path.<br/> Endpoints designated as Superadmin-only are not tenant-scoped.",
  "license": "Unlicense",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kestra-io/client-sdk.git"
  },
  "exports": {
    ".": "./dist/index.js",
    "./ai": "./dist/ai.js",
    "./apps": "./dist/apps.js",
    "./assets": "./dist/assets.js",
    "./audit-logs": "./dist/audit-logs.js",
    "./auths": "./dist/auths.js",
    "./banners": "./dist/banners.js",
    "./bindings": "./dist/bindings.js",
    "./blueprint-tags": "./dist/blueprint-tags.js",
    "./blueprints": "./dist/blueprints.js",
    "./client": "./dist/client.js",
    "./cluster": "./dist/cluster.js",
    "./dashboards": "./dist/dashboards.js",
    "./executions": "./dist/executions.js",
    "./files": "./dist/files.js",
    "./flows": "./dist/flows.js",
    "./groups": "./dist/groups.js",
    "./invitations": "./dist/invitations.js",
    "./kill-switches": "./dist/kill-switches.js",
    "./kv": "./dist/kv.js",
    "./login": "./dist/login.js",
    "./logs": "./dist/logs.js",
    "./metrics": "./dist/metrics.js",
    "./misc": "./dist/misc.js",
    "./namespaces": "./dist/namespaces.js",
    "./outputs": "./dist/outputs.js",
    "./plugins": "./dist/plugins.js",
    "./roles": "./dist/roles.js",
    "./scim-configuration": "./dist/scim-configuration.js",
    "./scim-groups": "./dist/scim-groups.js",
    "./scim-users": "./dist/scim-users.js",
    "./secrets": "./dist/secrets.js",
    "./security-integrations": "./dist/security-integrations.js",
    "./service-account": "./dist/service-account.js",
    "./services": "./dist/services.js",
    "./shared": "./dist/shared.js",
    "./tenant-access": "./dist/tenant-access.js",
    "./tenants": "./dist/tenants.js",
    "./test-suites": "./dist/test-suites.js",
    "./triggers": "./dist/triggers.js",
    "./users": "./dist/users.js",
    "./worker-auth": "./dist/worker-auth.js",
    "./worker-groups": "./dist/worker-groups.js",
    "./package.json": "./package.json"
