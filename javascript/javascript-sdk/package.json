    "./dashboards-admin": "./dist/dashboards-admin.js",
    "./executions": "./dist/executions.js",
    "./expressions": "./dist/expressions.js",
    "./files": "./dist/files.js",
    "./flows": "./dist/flows.js",
    "./groups": "./dist/groups.js",
    "./invitations": "./dist/invitations.js",
    "./kill-switches": "./dist/kill-switches.js",
    "./kv": "./dist/kv.js",
