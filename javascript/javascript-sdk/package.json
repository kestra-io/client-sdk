  "scripts": {
    "build": "tsdown",
    "dev": "node scripts/dev.mjs",
    "typecheck": "vue-tsc --noEmit",
    "generate:openapi": "openapi-ts",
    "prebuild": "openapi-ts"
  },
  "dependencies": {
    "nprogress": "0.2.0",
    "axios": "1.15.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.96.0",
    "@types/node": "^25.5.0",
    "@types/nprogress": "^0.2.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ]
}
