    "./roles": "./dist/roles.js",
    "./scim-configuration": "./dist/scim-configuration.js",
    "./scim-groups": "./dist/scim-groups.js",
    "./scim-users": "./dist/scim-users.js",
    "./secrets": "./dist/secrets.js",
    "./security-integrations": "./dist/security-integrations.js",
    "./service-account": "./dist/service-account.js",
    "./services": "./dist/services.js",
    "./shared": "./dist/shared.js",
    "./tenant-access": "./dist/tenant-access.js",
