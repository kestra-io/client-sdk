{
  "include": ["**/*.js", "../javascript_sdk/src/**/*.js"],
  "compilerOptions": {
    // Tells TypeScript to read JS files, as
    // normally they are ignored as source files
    "allowJs": true,
    "moduleResolution": "node16",
    "target": "ES2020",
    "module": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  }
}