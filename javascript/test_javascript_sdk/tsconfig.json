{
  "include": ["**/*.ts"],
  "compilerOptions": {
    // Tells TypeScript to read JS files, as
    // normally they are ignored as source files
    "allowJs": true,
    "outDir": "dist",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "module": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  }
}